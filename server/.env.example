# Copy to server/.env and fill in.
# Get NOTION_TOKEN from https://www.notion.so/profile/integrations
# (Create an internal integration, copy the secret)
# Then share the "Workout Log" database with that integration
# (Workout Log page → ••• menu → Connections → add your integration).

NOTION_TOKEN=ntn_your_token_here
NOTION_WORKOUT_DB_ID=c2045ab8-72f1-4b10-a538-be33008af84b
PORT=3001
